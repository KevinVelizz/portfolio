---
const { title, description, github, demo, tech } = Astro.props;
---

<div
  class="group flex flex-col justify-between backdrop-blur-md bg-white/5 border border-white/10 rounded-xl p-6
         hover:bg-white/10 hover:border-white/20
         transition duration-300 hover:scale-[1.02]"
>
  <h3 class="text-xl font-semibold group-hover:text-blue-500">
    {title}
  </h3>

  <p class="text-neutral-400 mt-3 text-sm leading-relaxed">
    {description}
  </p>

  <div class="flex flex-wrap gap-2 mt-4">
    {
      tech.map((t: string) => (
        <span class="text-xs bg-white/5 border border-white/10 px-2 py-1 rounded-md">
          {t}
        </span>
      ))
    }
  </div>

  <div class="flex gap-4 mt-6 text-lg">
    <a href={github} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-300 transition">
      <ion-icon name="logo-github"></ion-icon>
    </a>

    {
      demo && (
        <a href={demo} target="_blank" class="hover:text-blue-400 transition">
          <ion-icon name="open-outline" />
        </a>
      )
    }
  </div>
</div>
